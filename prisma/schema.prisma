generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  EDITOR
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  seoTitle    String?
  seoDescription String?
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([sortOrder])
}

model Product {
  id               String                 @id @default(cuid())
  name             String
  slug             String                 @unique
  modelNumber      String?
  shortDescription String?
  description      String?
  status           ProductStatus          @default(DRAFT)
  featured         Boolean                @default(false)
  sortOrder        Int                    @default(0)
  seoTitle         String?
  seoDescription   String?
  categoryId       String
  category         Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images           ProductImage[]
  specifications   ProductSpecification[]
  inquiryItems     InquiryItem[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  publishedAt      DateTime?

  @@index([status, featured, sortOrder])
  @@index([categoryId])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId, sortOrder])
}

model ProductSpecification {
  id        String  @id @default(cuid())
  label     String
  value     String
  group     String?
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Inquiry {
  id        String        @id @default(cuid())
  email     String
  company   String?
  name      String?
  phone     String?
  message   String
  voltage   String?
  range     String?
  quantity  String?
  status    InquiryStatus @default(NEW)
  items     InquiryItem[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, createdAt])
}

model InquiryItem {
  id        String  @id @default(cuid())
  inquiryId String
  productId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([inquiryId, productId])
}

model SiteSettings {
  id                      String   @id @default("site")
  brandTitle              String   @default("RIVERS")
  brandSubtitle           String   @default("RF CONTROL")
  whatsappEnabled         Boolean  @default(true)
  whatsappNumber          String   @default("")
  whatsappMessageTemplate String   @default("Hello, I am interested in {product}. Please send me more information.")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
