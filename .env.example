POSTGRES_USER="rivers"
POSTGRES_PASSWORD="rivers_local_dev_password"
POSTGRES_DB="rivers_website"
DATABASE_URL="postgresql://rivers:rivers_local_dev_password@localhost:5432/rivers_website?schema=public"
# Used by `npm run db:seed` to create or update the initial administrator.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
# Used to sign administrator sessions. Generate a long random value.
AUTH_SECRET="replace-with-a-long-random-string"

# Cloudflare R2 product image uploads
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public bucket URL or custom domain, for example https://images.example.com
R2_PUBLIC_URL=""
