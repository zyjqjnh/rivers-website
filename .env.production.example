# PostgreSQL container settings. Use a URL-safe password or percent-encode it in DATABASE_URL.
POSTGRES_USER="rivers"
POSTGRES_PASSWORD="replace-with-a-long-random-database-password"
POSTGRES_DB="rivers_website"
DATABASE_URL="postgresql://rivers:replace-with-a-long-random-database-password@postgres:5432/rivers_website?schema=public"

# Initial administrator credentials. ADMIN_PASSWORD is only used by the seed command.
ADMIN_EMAIL="admin@anrivers.com"
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Signs the 12-hour administrator session. Generate with: openssl rand -hex 64
AUTH_SECRET="replace-with-at-least-64-random-characters"

# Cloudflare R2 product image uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="https://images.anrivers.com"
